@startuml

' Settings
set separator ,
skinparam roundcorner 13
skinparam backgroundcolor #FFE299

' Structure
package java.util {
    interface List
    interface Map
    interface Set
    class ArrayList
    class HashMap
    class HashSet
    class LinkedList
}

package src.main.java.org.example {
    package app {
        class SportsManagementSystem
    }

    package commands {
        class PlayerCreateCommand
        class TeamCreateCommand
        class PlayerDeleteCommand
        class TeamDeleteCommand
        class TeamAddCommand
        class TeamRemoveCommand
        class TournamentCreateCommand
        class TournamentDeleteCommand
        class TournamentMatchmakingCommand
        class TournamentAddCommand
        class TournamentRemoveCommand
        class StatisticsShowCommand
        class LoginCommand
        class LogoutCommand
        class TournamentListCommand

        class ExitCommand
    }

    package models {
        enum Category
        abstract Command
        class Match <<deprecated>>
        class MatchList <<deprecated>>
        abstract Participant
        class ParticipantSet
        class Player
        enum Role
        class Team
        class Tournament
        class TournamentList
        class User
    }

    package views {
        class CLI
        class CommandView
        enum Error
        enum Message
        class ParticipantSetView
        class TournamentListView
    }
}

