@startuml

package src.main.java.org.example {
    package controllers {
        class CommandFactory {
            +getCommand(): Command
            -createCommands()
        }
        class Controller {
            -getPlayerFromCurrentUser(): Player
            -getTeamFromPlayer(Player): Team
            +hasPermission(Role[]): boolean
            +login(String, String): Error
            +logout()
            +createPlayer(String, String, String): Error
            +deletePlayer(String): Error
            +isPlayerParticipatingInAInProgressTournament(String): Error
            +showStats(String[]): String
            +addToTeam(String, String): Error
            +createTeam(String): Error
            +deleteTeam(String): Error
            +removeFromTeam(String): Error
            +addToTournament(String, String): Error
            +createTournament(String, String, String, String, String): Error
            +deleteTournament(String): Error
            +listTournaments(): String
            -tournamentListing(Role): String
            +tournamentMatchmake(String, String, String[]): Error
            +removeFromTournament(String, String): Error
        }
        class Database {
            +loadPlayers()
            +loadTeams()
            +loadTournaments()
            +loadUsers()
        }
    }

    package models {
        enum Category {
            POINTS_SCORED
            MATCHES_WON
            ASSIST_POINTS
            TOURNAMENTS_WON
            EARNINGS
        }
        interface Participant {
            rating(): double
            getFormat(): String
        }
        class Player implements Participant {
            +Player(String, String, String, String, Double[])
            +Player( String, String, String)
            +getIdentifier(): String
            +isUser(User): boolean
            +getStat(Category): double
            +getStatsFormat(String): String
            -statsDefault(): String
            -statsCSV(): String
            -statsJSON(): String
            +rating(): double
            +getFormat(): String
        }
        enum Role {
            ADMIN
            PLAYER
            GUEST
        }
        class Team implements Participant {
            +Team(String, String, String[])
            +getIdentifier(): String
            +add(Player): boolean
            +remove(Player): boolean
            +contains(Player): boolean
            -geometricMeans(): Map
            +getStatsFormat(): String
            +rating(): double
            +getFormat(): String
        }
        class Tournament {
            +getName(): String
            +isInProgress(): boolean
            +hasFinished(): boolean
            -toDate(String): Date
            +add(Participant): boolean
            +remove(Participant): boolean
            +contains(Participant): boolean
            +getFormat(): String
            +manualMatchmake(Participant[])
            +randomMatchmake(Participant[])
            +getSortedParticipantsFormat(): String
        }
        class Match {
            ~Match(Participant[])
            ~getFormat(): String
        }
        class User {
            +User(Role)
            +User(String, String, Role)
            +getEmail(): String
            +getRole(): Role
            +isPasswordCorrect(): boolean
        }
    }

    package utils {
        class Console {
            -{static}instance
            +{static}getInstance: Console
            +print(String)
            +println(String)
            +readLine(): String
        }
        enum Error {
            NONE
            COMMAND_NOT_FOUND
            NO_PERMISSION
            INCORRECT_ARGUMENT_COUNT
            ALREADY_LOGGED_ON
            NO_SUCH_USER
            INCORRECT_PASSWORD
            NOT_LOGGED_ON
            INCORRECT_ARGUMENT_FORMAT
            EXISTENT_PLAYER
            INEXISTENT_PLAYER
            EXISTENT_TEAM
            INEXISTENT_TEAM
            EXISTENT_TOURNAMENT
            INEXISTENT_TOURNAMENT
            PARTICIPANT_ON_TOURNAMENT_IN_PROGRESS
            NO_SUCH_OPTION
            PLAYER_ALREADY_IN_TEAM
            PARTICIPANT_ALREADY_IN_TOURNAMENT
            TOURNAMENT_IN_PROGRESS
        }
    }

    package views {
        package commands {
            abstract Command {
            }
            interface CommandToExit {
                #hasBeenExecuted(): boolean
            }
            class ConcreteCommand extends Command {
            }
            class ExitCommand extends Command
        }
        class CLI {
            +{static}main(String[])
            -start()
            -getCommand(String): Command
            -getArguments(String): String[]
        }
        enum Message {
            WELCOME
            PROMT
            BYE
        }
    }
}

CommandFactory --> CLI
CommandFactory --> Controller
CLI --> Command
Command --> Controller

Console <-- CLI
Console <-- Command
Console <-- ConcreteCommand

Tournament +-- Match
Tournament o-- Match
Participant o-- Match

Message --+ CLI
Message <.. CLI
CommandToExit <-- CLI
Role <-- User
Team <.. Category
Player <-- Category

Error <.. Command
Error <.. ConcreteCommand
Error <.. Controller
Error <.. CLI

Controller <-- User
Controller o-- Player
Controller o-- Team
Controller o-- Tournament
Controller o-- User
Controller <-- Database

@enduml